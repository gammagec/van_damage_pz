PZ_SERVER_NAME=ProdServer
PZ_ADMIN_USERNAME=admin
PZ_JAVA_XMS=4g
PZ_JAVA_XMX=8g
PZ_STEAM_VAC=true
# Steam beta branch to install, e.g. "unstable" for the build 42 test branch.
# Leave empty for the default stable branch. Switching branches on a volume
# with existing saves can make them fail to load (world formats can differ
# between branches) -- wipe the volume or use a fresh one when switching.
PZ_BETA_BRANCH=unstable

HOST_GAME_PORT=8866
HOST_PLAYER_PORT_RANGE=16361-16362
